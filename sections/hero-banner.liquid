{%- style -%}
  .hero-banner {
    position: relative;
    height: 100vh;
    max-height: 600px;
    background-color: #1F1F1F;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-banner__image {
    position: absolute;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  .hero-banner__overlay {
    position: absolute;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.4);
    z-index: 2;
  }

  .hero-banner__content {
    position: relative;
    z-index: 3;
    text-align: center;
    color: #FFFFFF;
    max-width: 600px;
    padding: 2rem;
  }

  .hero-banner__title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 8vw, 4rem);
    margin-bottom: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .hero-banner__subtitle {
    font-family: 'Inter', sans-serif;
    font-size: clamp(1rem, 3vw, 1.5rem);
    margin-bottom: 2rem;
    font-weight: 300;
    letter-spacing: 1px;
  }

  .hero-banner__cta {
    display: inline-block;
    background-color: #D4AF37;
    color: #1F1F1F;
    padding: 1rem 2.5rem;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
    border: 2px solid #D4AF37;
    cursor: pointer;
    border-radius: 4px;
    font-family: 'Inter', sans-serif;
  }

  .hero-banner__cta:hover {
    background-color: transparent;
    color: #D4AF37;
  }

  @media (max-width: 767px) {\n    .hero-banner {\n      max-height: 400px;\n    }\n\n    .hero-banner__title {\n      font-size: 2rem;\n    }\n\n    .hero-banner__subtitle {\n      font-size: 1rem;\n    }\n\n    .hero-banner__cta {\n      padding: 0.75rem 2rem;\n      font-size: 0.9rem;\n    }\n  }\n{%- endstyle -%}\n\n<div class=\"hero-banner\">\n  {% if section.settings.image %}\n    <img src=\"{{ section.settings.image | image_url: width: 1920 }}\" alt=\"{{ section.settings.title }}\" class=\"hero-banner__image\" loading=\"lazy\">\n  {% endif %}\n  <div class=\"hero-banner__overlay\"></div>\n  <div class=\"hero-banner__content\">\n    <h1 class=\"hero-banner__title\">{{ section.settings.title }}</h1>\n    <p class=\"hero-banner__subtitle\">{{ section.settings.subtitle }}</p>\n    {% if section.settings.cta_url %}\n      <a href=\"{{ section.settings.cta_url }}\" class=\"hero-banner__cta\">{{ section.settings.cta_text }}</a>\n    {% endif %}\n  </div>\n</div>\n\n{% schema %}\n{\n  \"name\": \"Hero Banner\",\n  \"settings\": [\n    {\n      \"type\": \"image_picker\",\n      \"id\": \"image\",\n      \"label\": \"Hero Image\"\n    },\n    {\n      \"type\": \"text\",\n      \"id\": \"title\",\n      \"label\": \"Title\",\n      \"default\": \"Welcome to PetteLuxe\"\n    },\n    {\n      \"type\": \"text\",\n      \"id\": \"subtitle\",\n      \"label\": \"Subtitle\",\n      \"default\": \"Luxury Pet Fashion for Discerning Pet Parents\"\n    },\n    {\n      \"type\": \"text\",\n      \"id\": \"cta_text\",\n      \"label\": \"CTA Button Text\",\n      \"default\": \"Shop Now\"\n    },\n    {\n      \"type\": \"url\",\n      \"id\": \"cta_url\",\n      \"label\": \"CTA Button URL\"\n    }\n  ],\n  \"presets\": [\n    {\n      \"name\": \"Hero Banner\"\n    }\n  ]\n}\n{% endschema %}