{%- style -%}
  .header {
    background-color: #FFFFFF;
    border-bottom: 1px solid #EAE3D5;
    padding: 1rem 0;
    position: sticky;
    top: 0;
    z-index: 1000;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  }

  .header__inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .header__logo {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 120px;
  }

  .header__logo img {
    max-height: 50px;
    width: auto;
    display: block;
  }

  .header__nav {
    display: none;
    gap: 2rem;
    flex: 1;
  }

  .header__nav a {
    color: #1F1F1F;
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    transition: color 0.3s ease;
    position: relative;
  }

  .header__nav a:hover {
    color: #D4AF37;
  }

  .header__nav a::after {
    content: '';
    position: absolute;
    bottom: -5px;
    left: 0;
    width: 0;
    height: 2px;
    background-color: #D4AF37;
    transition: width 0.3s ease;
  }

  .header__nav a:hover::after {
    width: 100%;
  }

  .header__actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .header__icon-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.3s ease;
    color: #1F1F1F;
  }

  .header__icon-btn:hover {
    color: #D4AF37;
  }

  .header__hamburger {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    cursor: pointer;
  }

  .header__hamburger span {
    width: 24px;
    height: 2px;
    background-color: #1F1F1F;
    transition: all 0.3s ease;
  }

  .header__hamburger.active span:nth-child(1) {
    transform: rotate(45deg) translate(10px, 10px);
  }

  .header__hamburger.active span:nth-child(2) {
    opacity: 0;
  }

  .header__hamburger.active span:nth-child(3) {
    transform: rotate(-45deg) translate(7px, -7px);
  }

  .header__mobile-nav {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background-color: #FFFFFF;
    border-bottom: 1px solid #EAE3D5;
    flex-direction: column;
    padding: 1rem;
    gap: 0.5rem;
  }

  .header__mobile-nav.active {
    display: flex;
  }

  .header__mobile-nav a {
    padding: 0.75rem;
    color: #1F1F1F;
    text-decoration: none;
  }

  .header__cart-count {
    position: absolute;
    top: -5px;
    right: -8px;
    background-color: #D4AF37;
    color: #FFFFFF;
    border-radius: 50%;
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: bold;
  }

  @media (min-width: 768px) {
    .header__nav {
      display: flex;
    }

    .header__hamburger {
      display: none;
    }

    .header__mobile-nav {
      display: none !important;
    }
  }
{%- endstyle -%}

<header class=\"header\">\n  <div class=\"header__inner\">\n    <div class=\"header__logo\">\n      {% if settings.logo %}\n        <a href=\"/\">\n          <img src=\"{{ settings.logo | image_url: width: 200 }}\" alt=\"{{ shop.name }}\" loading=\"lazy\">\n        </a>\n      {% else %}\n        <a href=\"/\" style=\"font-size: 1.5rem; color: #1F1F1F; text-decoration: none;\">\n          {{ shop.name }}\n        </a>\n      {% endif %}\n    </div>\n\n    <nav class=\"header__nav\">\n      <a href=\"/collections/dog-clothing\">Dog Clothing</a>\n      <a href=\"/collections/cat-clothing\">Cat Clothing</a>\n      <a href=\"/collections/toys\">Toys</a>\n      <a href=\"/collections/accessories\">Accessories</a>\n    </nav>\n\n    <div class=\"header__actions\">\n      <a href=\"/account\" class=\"header__icon-btn\">\n        <svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n          <path d=\"M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2\"></path>\n          <circle cx=\"12\" cy=\"7\" r=\"4\"></circle>\n        </svg>\n      </a>\n\n      <button class=\"header__icon-btn\" id=\"cart-trigger\" style=\"position: relative;\">\n        <svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n          <circle cx=\"9\" cy=\"21\" r=\"1\"></circle>\n          <circle cx=\"20\" cy=\"21\" r=\"1\"></circle>\n          <path d=\"M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6\"></path>\n        </svg>\n        {% if cart.item_count > 0 %}\n          <span class=\"header__cart-count\">{{ cart.item_count }}</span>\n        {% endif %}\n      </button>\n\n      <button class=\"header__icon-btn header__hamburger\" id=\"header-hamburger\">\n        <span></span>\n        <span></span>\n        <span></span>\n      </button>\n    </div>\n  </div>\n\n  <nav class=\"header__mobile-nav\" id=\"header-mobile-nav\">\n    <a href=\"/collections/dog-clothing\">Dog Clothing</a>\n    <a href=\"/collections/cat-clothing\">Cat Clothing</a>\n    <a href=\"/collections/toys\">Toys</a>\n    <a href=\"/collections/accessories\">Accessories</a>\n  </nav>\n</header>\n\n<script>\n  document.addEventListener('DOMContentLoaded', function() {\n    const hamburger = document.getElementById('header-hamburger');\n    const mobileNav = document.getElementById('header-mobile-nav');\n\n    if (hamburger) {\n      hamburger.addEventListener('click', function() {\n        hamburger.classList.toggle('active');\n        mobileNav.classList.toggle('active');\n      });\n    }\n  });\n</script>