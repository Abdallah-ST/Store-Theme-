{%- style -%}
  .why-choose-us {
    padding: 4rem 1.5rem;
    background: linear-gradient(135deg, #EAE3D5 0%, #FAF8F4 100%);
    max-width: 1440px;
    margin: 0 auto;
  }

  .why-choose-us__container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .why-choose-us__content h2 {
    font-family: 'Playfair Display', serif;
    font-size: 2.5rem;
    margin-bottom: 1.5rem;
    color: #1F1F1F;
  }

  .why-choose-us__content p {
    color: #666;
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  .why-choose-us__features {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .feature {
    display: flex;
    gap: 1rem;
  }

  .feature__icon {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    background-color: #D4AF37;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #FFFFFF;
    font-weight: bold;
  }

  .feature__title {
    font-weight: 600;
    color: #1F1F1F;
    margin-bottom: 0.5rem;
  }

  .feature__description {
    color: #666;
    font-size: 0.9rem;
  }

  .why-choose-us__image {
    border-radius: 8px;
    overflow: hidden;
  }

  .why-choose-us__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 767px) {
    .why-choose-us {
      padding: 2rem 1.5rem;
    }

    .why-choose-us__container {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .why-choose-us__content h2 {
      font-size: 1.75rem;
    }
  }
{%- endstyle -%}

<section class="why-choose-us">
  <div class="why-choose-us__container">
    <div class="why-choose-us__content">
      <h2>{{ section.settings.title }}</h2>
      <p>{{ section.settings.description }}</p>
      
      <div class="why-choose-us__features">
        {% for i in (1..3) %}
          {% assign feature_key = 'feature_' | append: i %}
          {% assign desc_key = 'feature_desc_' | append: i %}
          <div class="feature">
            <div class="feature__icon">✓</div>
            <div>
              <div class="feature__title">{{ section.settings[feature_key] }}</div>
              <div class="feature__description">{{ section.settings[desc_key] }}</div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>

    <div class="why-choose-us__image">
      {% if section.settings.image %}
        <img src="{{ section.settings.image | image_url: width: 800 }}" alt="Why Choose PetteLuxe" loading="lazy">
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Why Choose Us",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Why Choose PetteLuxe"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "We are dedicated to providing the finest luxury pet fashion and accessories for your beloved companions."
    },
    {
      "type": "text",
      "id": "feature_1",
      "label": "Feature 1 Title",
      "default": "Premium Quality"
    },
    {
      "type": "text",
      "id": "feature_desc_1",
      "label": "Feature 1 Description",
      "default": "Handpicked materials and expert craftsmanship"
    },
    {
      "type": "text",
      "id": "feature_2",
      "label": "Feature 2 Title",
      "default": "Sustainable Design"
    },
    {
      "type": "text",
      "id": "feature_desc_2",
      "label": "Feature 2 Description",
      "default": "Eco-friendly materials and ethical production"
    },
    {
      "type": "text",
      "id": "feature_3",
      "label": "Feature 3 Title",
      "default": "Expert Support"
    },
    {
      "type": "text",
      "id": "feature_desc_3",
      "label": "Feature 3 Description",
      "default": "24/7 customer service for your peace of mind"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Section Image"
    }
  ],
  "presets": [
    {
      "name": "Why Choose Us"
    }
  ]
}
{% endschema %}