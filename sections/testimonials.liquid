{%- style -%}
  .testimonials {
    padding: 4rem 1.5rem;
    background-color: #FAF8F4;
    max-width: 1440px;
    margin: 0 auto;
  }

  .testimonials__title {
    font-family: 'Playfair Display', serif;
    font-size: 2.5rem;
    text-align: center;
    margin-bottom: 3rem;
    color: #1F1F1F;
  }

  .testimonials__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .testimonial-card {
    background-color: #FFFFFF;
    padding: 2rem;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  .testimonial-card__rating {
    display: flex;
    gap: 0.25rem;
    margin-bottom: 1rem;
  }

  .star {
    color: #D4AF37;
    font-size: 1.2rem;
  }

  .testimonial-card__text {
    color: #666;
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
    font-style: italic;
  }

  .testimonial-card__author {
    font-weight: 600;
    color: #1F1F1F;
    margin-bottom: 0.25rem;
  }

  .testimonial-card__title {
    font-size: 0.85rem;
    color: #999;
  }

  @media (max-width: 767px) {
    .testimonials {
      padding: 2rem 1.5rem;
    }

    .testimonials__title {
      font-size: 1.75rem;
    }

    .testimonials__grid {
      grid-template-columns: 1fr;
    }
  }
{%- endstyle -%}

<section class="testimonials">
  <h2 class="testimonials__title">{{ section.settings.title }}</h2>

  <div class="testimonials__grid">
    {% for i in (1..3) %}
      {% assign text_key = 'testimonial_' | append: i %}
      {% assign author_key = 'author_' | append: i %}
      {% assign title_key = 'author_title_' | append: i %}
      <div class="testimonial-card">
        <div class="testimonial-card__rating">
          <span class="star">★</span>
          <span class="star">★</span>
          <span class="star">★</span>
          <span class="star">★</span>
          <span class="star">★</span>
        </div>
        <p class="testimonial-card__text">"{{ section.settings[text_key] }}"</p>
        <div class="testimonial-card__author">{{ section.settings[author_key] }}</div>
        <div class="testimonial-card__title">{{ section.settings[title_key] }}</div>
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "What Our Customers Say"
    },
    {
      "type": "textarea",
      "id": "testimonial_1",
      "label": "Testimonial 1 Text",
      "default": "PetteLuxe's products are absolutely stunning! My dog looks like royalty in her new outfit."
    },
    {
      "type": "text",
      "id": "author_1",
      "label": "Testimonial 1 Author",
      "default": "Sarah M."
    },
    {
      "type": "text",
      "id": "author_title_1",
      "label": "Testimonial 1 Title",
      "default": "Verified Buyer"
    },
    {
      "type": "textarea",
      "id": "testimonial_2",
      "label": "Testimonial 2 Text",
      "default": "Excellent quality and amazing customer service. Highly recommend!"
    },
    {
      "type": "text",
      "id": "author_2",
      "label": "Testimonial 2 Author",
      "default": "Emma K."
    },
    {
      "type": "text",
      "id": "author_title_2",
      "label": "Testimonial 2 Title",
      "default": "Verified Buyer"
    },
    {
      "type": "textarea",
      "id": "testimonial_3",
      "label": "Testimonial 3 Text",
      "default": "Finally found a brand that understands luxury pet fashion. Love everything!"
    },
    {
      "type": "text",
      "id": "author_3",
      "label": "Testimonial 3 Author",
      "default": "Lisa B."
    },
    {
      "type": "text",
      "id": "author_title_3",
      "label": "Testimonial 3 Title",
      "default": "Verified Buyer"
    }
  ],
  "presets": [
    {
      "name": "Testimonials"
    }
  ]
}
{% endschema %}