{% paginate collection.products by 12 %}

<div style="padding: 2rem 1.5rem; max-width: 1440px; margin: 0 auto;">
  <h1 style="font-family: 'Playfair Display', serif; font-size: 2rem; margin-bottom: 2rem; color: #1F1F1F;">
    {{ collection.title }}
  </h1>

  <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 2rem; margin-bottom: 2rem;">
    {% for product in collection.products %}
      <div style="text-align: center;">
        {% if product.featured_image %}
          <div style="position: relative; overflow: hidden; border-radius: 8px; aspect-ratio: 1; background-color: #FAF8F4; margin-bottom: 1rem;">
            <img src="{{ product.featured_image | image_url: width: 500 }}" alt="{{ product.title }}" style="width: 100%; height: 100%; object-fit: cover;">
          </div>
        {% endif %}
        <h3 style="font-family: 'Playfair Display', serif; font-size: 1.1rem; margin-bottom: 0.5rem; color: #1F1F1F;">
          {{ product.title }}
        </h3>
        <p style="color: #D4AF37; font-weight: 600; margin-bottom: 1rem;">
          {{ product.price | money_with_currency }}
        </p>
        <a href="{{ product.url }}" style="display: inline-block; background-color: #1F1F1F; color: #FFFFFF; padding: 0.75rem 1.5rem; text-decoration: none; border-radius: 4px; transition: all 0.3s ease;">
          View Product
        </a>
      </div>
    {% endfor %}
  </div>

  {% if paginate.pages > 1 %}
    <div style="text-align: center; margin-top: 2rem;">
      {{ paginate | default_pagination }}
    </div>
  {% endif %}
</div>

{% endpaginate %}